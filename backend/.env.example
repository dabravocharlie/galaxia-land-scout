# Copy this to .env for local development. On Render, set these as
# environment variables in the dashboard instead of using this file.

# Postgres connection string (Render Postgres provides this automatically
# as an "Internal Database URL" you can paste in)
DATABASE_URL=postgresql://user:password@localhost:5432/galaxia_land_scout

# Port the server listens on (Render sets this automatically in production)
PORT=3001

# SendGrid API key for email digests/alerts (same one used by Stock News Bot,
# or a new key if you want to keep them separate)
SENDGRID_API_KEY=

# Email addresses
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# Set to 'false' to disable the cron scheduler (useful for local dev so you
# don't accidentally trigger scrapers while testing)
ENABLE_SCHEDULER=true

# ScraperAPI key (free tier at scraperapi.com) — used by the retail scraper
# (LandSearch/LandWatch) to get past their datacenter-IP blocks. Leave blank
# to disable retail scraping; Craigslist and the tracker don't need it.
SCRAPERAPI_KEY=

# Anthropic API key — used by the tech stock discovery job (web search to
# surface notable tech names). Same key you use for Stock News Bot works fine.
# Leave blank to disable tech discovery.
ANTHROPIC_API_KEY=
